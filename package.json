{
	"name": "obsidian-atomic-notes",
	"version": "2.1.6",
	"description": "AI 提炼原子笔记，过滤信息垃圾，把阅读转化为可检索的知识节点 | Extract atomic notes from articles, links, or selected text using AI, filter noise, and turn reading into searchable knowledge nodes.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"sync": "bash sync.sh",
		"sync:dev": "bash sync.sh --dev",
		"sync:check": "bash sync.sh --check",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:coverage:check": "node scripts/check-incremental-coverage.mjs",
		"lint": "eslint src/ --ext .ts",
		"lint:fix": "eslint src/ --ext .ts --fix",
		"format": "prettier --write src/"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"atomic",
		"notes",
		"AI"
	],
	"author": "羽鳞君",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "^7.2.0",
		"@typescript-eslint/parser": "^7.2.0",
		"@vitest/coverage-v8": "^0.34.6",
		"esbuild": "^0.20.0",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-prettier": "^5.5.6",
		"jsdom": "^24.1.3",
		"obsidian": "^1.0.0",
		"prettier": "^3.8.4",
		"typescript": "^5.0.0",
		"vitest": "^0.34.6"
	}
}
